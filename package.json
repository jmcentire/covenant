{
  "name": "@stack/covenant",
  "version": "0.1.1",
  "description": "Contract validation runtime: per-env policy + sliding-window violation budget. Zod-canonical.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts/*": {
      "types": "./dist/contracts/*.d.ts",
      "import": "./dist/contracts/*.js"
    }
  },
  "bin": {
    "covenant-export": "./bin/covenant-export.ts"
  },
  "files": [
    "dist",
    "bin",
    "src",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "export": "tsx bin/covenant-export.ts",
    "export:check": "tsx bin/covenant-export.ts --check"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmcentire/covenant.git"
  },
  "homepage": "https://github.com/jmcentire/covenant#readme",
  "bugs": {
    "url": "https://github.com/jmcentire/covenant/issues"
  }
}
